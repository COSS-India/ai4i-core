pipeline {

  agent any

  parameters {
    string(name: 'BRANCH_NAME', defaultValue: 'devops', description: 'Git branch to deploy from')
    choice(name: 'SERVICE_NAME', choices: """
alerting-service
api-gateway-service
asr-service
auth-service
config-service
dashboard-service
metrics-service
nmt-service
pipeline-service
telemetry-service
tts-service
simple-ui
""")
    string(name: 'IMAGE_URI', defaultValue: '', description: 'Full ECR image URI')
  }

  environment {
    GIT_REPO      = 'https://github.com/COSS-India/ai4i-core.git'
    AWS_REGION    = 'ap-south-1'
    EKS_CLUSTER   = 'AI4Voice-core'
    K8S_NAMESPACE = 'dev'
    BASTION_HOST  = '13.235.32.90'
    BASTION_USER  = 'ubuntu'
  }

  stages {

    /* 1. VALIDATION */
    stage('Validate Input') {
      steps {
        script {
          if (!params.IMAGE_URI?.trim()) {
            error("❌ IMAGE_URI is required")
          }
          echo "Deploying service: ${params.SERVICE_NAME}"
          echo "Image: ${params.IMAGE_URI}"
        }
      }
    }

    /* 2. CHECKOUT */
    stage('Checkout Repository') {
      steps {
        echo "📥 Checking out repository..."
        checkout([
          $class: 'GitSCM',
          branches: [[name: "*/${params.BRANCH_NAME}"]],
          userRemoteConfigs: [[url: "${env.GIT_REPO}"]]
        ])

        script {
          env.MANIFEST_PATH = "k8's_manifest/${params.SERVICE_NAME}"

          if (!fileExists(env.MANIFEST_PATH)) {
            error "❌ Kubernetes manifests not found at: ${env.MANIFEST_PATH}"
          }

          echo "✓ Found manifests at ${env.MANIFEST_PATH}"
        }
      }
    }

    /* 3. BASTION CONNECTIVITY CHECK */
    stage('Pre-deploy Bastion Check') {
      steps {
        withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh', keyFileVariable: 'SSH_KEY')]) {
          sh """
            echo "🔐 Checking bastion connectivity..."

            ssh -o StrictHostKeyChecking=no -i "\$SSH_KEY" ${BASTION_USER}@${BASTION_HOST} \
              'echo "SSH OK"; which aws; which kubectl'
          """
        }
      }
    }

    /* 4. APPLY MANIFESTS VIA BASTION */
    stage('Apply Kubernetes Manifests') {
      steps {
        echo "📦 Copying manifests to bastion..."
        withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh', keyFileVariable: 'SSH_KEY')]) {

          sh """
            set -eux

            # Create temp dir on bastion
            TEMP_DIR=\$(ssh -o StrictHostKeyChecking=no -i "\$SSH_KEY" ${BASTION_USER}@${BASTION_HOST} \
              'mktemp -d /tmp/k8s-manifest-XXXX')

            echo "Temp directory: \$TEMP_DIR"

            # Copy the manifest directory
            scp -o StrictHostKeyChecking=no -i "\$SSH_KEY" -r "${MANIFEST_PATH}/"* ${BASTION_USER}@${BASTION_HOST}:"\$TEMP_DIR/"

            echo "🚀 Applying YAML manifests..."

            ssh -o StrictHostKeyChecking=no -i "\$SSH_KEY" ${BASTION_USER}@${BASTION_HOST} bash <<EOF
set -eux

aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER}

cd "\$TEMP_DIR"

kubectl apply -f . -n ${K8S_NAMESPACE}

EOF
          """
        }
      }
    }

    /* 5. UPDATE DEPLOYMENT IMAGE */
    stage('Deploy to EKS') {
      steps {
        echo "🚀 Updating deployment ${params.SERVICE_NAME} with new image..."

        withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh', keyFileVariable: 'SSH_KEY')]) {
          sh """
            ssh -o StrictHostKeyChecking=no -i "\$SSH_KEY" ${BASTION_USER}@${BASTION_HOST} bash <<EOF
set -eux

aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER}

echo "🔄 Setting new image on deployment/${SERVICE_NAME}"

kubectl -n ${K8S_NAMESPACE} set image deployment/${SERVICE_NAME} \\
  ${SERVICE_NAME}=${IMAGE_URI} --record

kubectl -n ${K8S_NAMESPACE} rollout status deployment/${SERVICE_NAME} --timeout=180s

EOF
          """
        }
      }
    }
  }

  post {
    success {
      echo """
✅ Deployment Successful!
Service:   ${params.SERVICE_NAME}
Image:     ${params.IMAGE_URI}
Namespace: ${env.K8S_NAMESPACE}
Cluster:   ${env.EKS_CLUSTER}
"""
    }
    failure {
      echo """
❌ Deployment Failed
Service:   ${params.SERVICE_NAME}
Image:     ${params.IMAGE_URI}
Namespace: ${env.K8S_NAMESPACE}
Cluster:   ${env.EKS_CLUSTER}

👉 Check console log for details.
"""
    }
  }
}
