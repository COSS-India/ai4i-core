pipeline {
  agent any

  parameters {
    string(name: 'BRANCH_NAME', defaultValue: 'devops', description: 'Git branch')
    choice(name: 'SERVICE_NAME', choices: """
alerting-service
api-gateway-service
asr-service
auth-service
config-service
dashboard-service
metrics-service
nmt-service
pipeline-service
telemetry-service
tts-service
""", description: 'Service to deploy')
    string(name: 'IMAGE_URI', defaultValue: '', description: 'REQUIRED: Full ECR image URI. Example: 662074586476.dkr.ecr.ap-south-1.amazonaws.com/ai4voice/nmt-service:14112025-101038-IST')
    string(name: 'ROLLOUT_TIMEOUT', defaultValue: '180s', description: 'Rollout timeout (e.g. 180s or 5m)')
    booleanParam(name: 'DEBUG_MODE', defaultValue: false, description: 'Enable verbose SSH debugging')
  }

  environment {
    AWS_REGION    = 'ap-south-1'
    EKS_CLUSTER   = 'AI4Voice-core'
    K8S_NAMESPACE = 'dev'
    BASTION_HOST  = '13.235.32.90'
    BASTION_USER  = 'ubuntu'
  }

  stages {
    stage('Validate Parameters') {
      steps {
        script {
          if (!params.IMAGE_URI || params.IMAGE_URI.trim() == '') {
            error "IMAGE_URI parameter is required! Please provide the full ECR image URI."
          }
          env.DEPLOY_IMAGE = params.IMAGE_URI.trim()
          echo "================================================"
          echo "Deployment Configuration"
          echo "================================================"
          echo "Service: ${params.SERVICE_NAME}"
          echo "Image: ${env.DEPLOY_IMAGE}"
          echo "Namespace: ${env.K8S_NAMESPACE}"
          echo "Cluster: ${env.EKS_CLUSTER}"
          echo "================================================"
        }
      }
    }

    stage('Pre-deploy Bastion Check') {
      steps {
        withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh', keyFileVariable: 'SSH_KEY', usernameVariable: 'SSH_USER')]) {
          script {
            def sshOpts = params.DEBUG_MODE ? '-vvv' : '-v'
            sh """
              set -eu
              echo '================================================'
              echo 'Testing bastion connectivity...'
              echo 'Host: ${BASTION_HOST}'
              echo 'User: ${BASTION_USER}'
              echo '================================================'
              
              # Test SSH connection
              ssh ${sshOpts} -i "\${SSH_KEY}" -o StrictHostKeyChecking=no -o ConnectTimeout=15 ${BASTION_USER}@${BASTION_HOST} 'echo "✓ Connected"; hostname; whoami'
              
              # Verify required tools
              ssh -i "\${SSH_KEY}" -o StrictHostKeyChecking=no ${BASTION_USER}@${BASTION_HOST} 'which aws && which kubectl && echo "✓ Tools available"'
              
              echo '✅ Bastion ready for deployment'
              echo '================================================'
            """
          }
        }
      }
    }

    stage('Deploy to EKS') {
      steps {
        withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh', keyFileVariable: 'SSH_KEY', usernameVariable: 'SSH_USER')]) {
          sh """
            ssh -i "\${SSH_KEY}" -o StrictHostKeyChecking=no -o ServerAliveInterval=30 ${BASTION_USER}@${BASTION_HOST} bash -s <<'ENDSSH'
set -eu

echo "================================================"
echo "Starting EKS Deployment"
echo "================================================"
echo "Cluster: ${EKS_CLUSTER}"
echo "Namespace: ${K8S_NAMESPACE}"
echo "Service: ${SERVICE_NAME}"
echo "Image: ${DEPLOY_IMAGE}"
echo "================================================"

# Update kubeconfig
echo ""
echo "[1/4] Updating kubeconfig..."
aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER}

# Verify cluster
echo ""
echo "[2/4] Verifying cluster connectivity..."
kubectl cluster-info | head -1
kubectl get nodes --no-headers | wc -l | xargs -I {} echo "Connected to cluster with {} nodes"

# Update deployment
echo ""
echo "[3/4] Updating deployment image..."
kubectl -n ${K8S_NAMESPACE} set image deployment/${SERVICE_NAME} ${SERVICE_NAME}=${DEPLOY_IMAGE} --record
echo "✓ Image updated to: ${DEPLOY_IMAGE}"

# Wait for rollout
echo ""
echo "[4/4] Waiting for rollout (timeout: ${ROLLOUT_TIMEOUT})..."
if kubectl -n ${K8S_NAMESPACE} rollout status deployment/${SERVICE_NAME} --timeout=${ROLLOUT_TIMEOUT}; then
  echo "✅ Rollout completed successfully"
else
  echo "❌ Rollout failed or timed out"
  echo ""
  echo "Current pod status:"
  kubectl -n ${K8S_NAMESPACE} get pods -l app=${SERVICE_NAME} -o wide
  echo ""
  echo "Recent events:"
  kubectl -n ${K8S_NAMESPACE} get events --sort-by='.lastTimestamp' | tail -10
  exit 1
fi

# Final status
echo ""
echo "================================================"
echo "✅ Deployment Complete"
echo "================================================"
echo ""
echo "Deployment Status:"
kubectl -n ${K8S_NAMESPACE} get deployment ${SERVICE_NAME} -o wide
echo ""
echo "Pod Status:"
kubectl -n ${K8S_NAMESPACE} get pods -l app=${SERVICE_NAME} -o wide
echo ""
echo "================================================"

ENDSSH
"""
        }
      }
    }

    stage('Verification') {
      steps {
        echo ""
        echo "================================================"
        echo "✅ Deployment Verification"
        echo "================================================"
        echo "Service: ${params.SERVICE_NAME}"
        echo "Image: ${env.DEPLOY_IMAGE}"
        echo "Namespace: ${env.K8S_NAMESPACE}"
        echo "Cluster: ${env.EKS_CLUSTER}"
        echo "================================================"
        echo ""
        echo "Manual inspection commands (run on bastion):"
        echo "  ssh -i <key> ${env.BASTION_USER}@${env.BASTION_HOST}"
        echo ""
        echo "  # Check deployment"
        echo "  kubectl -n ${env.K8S_NAMESPACE} get deployment ${params.SERVICE_NAME} -o wide"
        echo ""
        echo "  # Check pods"
        echo "  kubectl -n ${env.K8S_NAMESPACE} get pods -l app=${params.SERVICE_NAME}"
        echo ""
        echo "  # View logs"
        echo "  kubectl -n ${env.K8S_NAMESPACE} logs -l app=${params.SERVICE_NAME} --tail=50 -f"
        echo ""
        echo "  # Describe deployment (for troubleshooting)"
        echo "  kubectl -n ${env.K8S_NAMESPACE} describe deployment ${params.SERVICE_NAME}"
        echo "================================================"
      }
    }
  }

  post {
    success { 
      echo ""
      echo "✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅"
      echo "✅                                              ✅"
      echo "✅          DEPLOYMENT SUCCESSFUL               ✅"
      echo "✅                                              ✅"
      echo "✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅"
      echo ""
      echo "  Service:   ${params.SERVICE_NAME}"
      echo "  Image:     ${env.DEPLOY_IMAGE}"
      echo "  Namespace: ${env.K8S_NAMESPACE}"
      echo "  Cluster:   ${env.EKS_CLUSTER}"
      echo "  Time:      ${new Date()}"
      echo ""
      echo "✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅"
      echo ""
    }
    failure { 
      echo ""
      echo "❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌"
      echo "❌                                              ❌"
      echo "❌          DEPLOYMENT FAILED                   ❌"
      echo "❌                                              ❌"
      echo "❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌"
      echo ""
      echo "  Service: ${params.SERVICE_NAME}"
      echo "  Image:   ${env.DEPLOY_IMAGE ?: 'Not set'}"
      echo ""
      echo "Troubleshooting Steps:"
      echo "  1. Run with DEBUG_MODE=true for verbose SSH logs"
      echo "  2. Verify IMAGE_URI exists in ECR repository"
      echo "  3. Check SSH credential 'bastion-ssh' in Jenkins"
      echo "  4. Verify bastion connectivity:"
      echo "     ssh -i <key> ${env.BASTION_USER}@${env.BASTION_HOST}"
      echo "  5. Check EKS cluster access from bastion:"
      echo "     aws eks update-kubeconfig --region ${env.AWS_REGION} --name ${env.EKS_CLUSTER}"
      echo "     kubectl get nodes"
      echo "  6. Verify deployment exists:"
      echo "     kubectl -n ${env.K8S_NAMESPACE} get deployment ${params.SERVICE_NAME}"
      echo ""
      echo "❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌"
      echo ""
    }
    always {
      echo "Pipeline execution completed at: ${new Date()}"
    }
  }
}
