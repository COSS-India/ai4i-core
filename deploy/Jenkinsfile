pipeline {
  agent any

  parameters {
    string(name: 'BRANCH_NAME', defaultValue: 'devops', description: 'Git branch to deploy from')
    choice(name: 'SERVICE_NAME', choices: """
alerting-service
api-gateway-service
asr-service
auth-service
config-service
dashboard-service
metrics-service
nmt-service
pipeline-service
telemetry-service
tts-service
simple-ui
""", description: 'Service to deploy')
    string(name: 'IMAGE_URI', defaultValue: '', description: 'REQUIRED: Full ECR image URI.')
    string(name: 'ROLLOUT_TIMEOUT', defaultValue: '180s', description: 'Rollout timeout')
    booleanParam(name: 'APPLY_MANIFESTS', defaultValue: true, description: 'Apply manifests?')
    booleanParam(name: 'FIX_DNS_HOSTNAMES', defaultValue: true, description: 'Fix DNS hostnames?')
    booleanParam(name: 'DEBUG_MODE', defaultValue: false, description: 'Enable SSH debug')
  }

  environment {
    GIT_REPO      = 'https://github.com/COSS-India/ai4i-core.git'
    AWS_REGION    = 'ap-south-1'
    EKS_CLUSTER   = 'AI4Voice-core'
    K8S_NAMESPACE = 'dev'
    BASTION_HOST  = '13.235.32.90'
    BASTION_USER  = 'ubuntu'
  }

  stages {

    /* ---------------------------------------------------
     * VALIDATION
     * --------------------------------------------------- */
    stage('Validate Parameters') {
      steps {
        script {
          if (!params.IMAGE_URI?.trim()) {
            error "IMAGE_URI parameter is required!"
          }
          env.DEPLOY_IMAGE = params.IMAGE_URI.trim()
          echo "================================================"
          echo "Service: ${params.SERVICE_NAME}"
          echo "Image:   ${env.DEPLOY_IMAGE}"
          echo "Branch:  ${params.BRANCH_NAME}"
          echo "================================================"
        }
      }
    }

    /* ---------------------------------------------------
     * CHECKOUT
     * --------------------------------------------------- */
    stage('Checkout Repository') {
      when { expression { return params.APPLY_MANIFESTS } }
      steps {
        echo "Checking out ${params.BRANCH_NAME} ..."
        checkout([
          $class: 'GitSCM',
          branches: [[name: "*/${params.BRANCH_NAME}"]],
          userRemoteConfigs: [[url: "${env.GIT_REPO}"]]
        ])

        /* FIXED MANIFEST LOOKUP */
        script {
          def manifestPath = "k8's_manifest/${params.SERVICE_NAME}"

          // ⚠ Special mapping for simple-ui
          if (params.SERVICE_NAME == "simple-ui") {
            manifestPath = "k8's_manifest/simple-ui-frontend"
          }

          echo "Searching manifests at: ${manifestPath}"

          if (!fileExists(manifestPath)) {
            error "❌ Kubernetes manifests not found at ${manifestPath}"
          }

          env.MANIFEST_PATH = manifestPath
          echo "✓ Found manifest directory: ${env.MANIFEST_PATH}"
        }
      }
    }

    /* ---------------------------------------------------
     * BASTION CHECK
     * --------------------------------------------------- */
    stage('Pre-deploy Bastion Check') {
      steps {
        withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh',
            keyFileVariable: 'SSH_KEY', usernameVariable: 'SSH_USER')]) {

          def sshOpts = params.DEBUG_MODE ? "-vvv" : "-v"

          sh """
            echo "Testing bastion..."
            ssh ${sshOpts} -i \$SSH_KEY -o StrictHostKeyChecking=no ${BASTION_USER}@${BASTION_HOST} "echo Connected"
          """
        }
      }
    }

    /* ---------------------------------------------------
     * APPLY MANIFESTS
     * --------------------------------------------------- */
    stage('Apply Kubernetes Manifests') {
      when { expression { return params.APPLY_MANIFESTS } }
      steps {
        withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh',
            keyFileVariable: 'SSH_KEY', usernameVariable: 'SSH_USER')]) {

          sh """
            set -eu
            echo "Copying manifests from: ${MANIFEST_PATH}"

            TEMP_DIR=\$(ssh -i "\$SSH_KEY" -o StrictHostKeyChecking=no ${BASTION_USER}@${BASTION_HOST} "mktemp -d /tmp/k8s.XXXX")
            echo "Temp directory: \$TEMP_DIR"

            scp -i "\$SSH_KEY" -o StrictHostKeyChecking=no -r "${MANIFEST_PATH}/"* ${BASTION_USER}@${BASTION_HOST}:\$TEMP_DIR/

            ssh -i "\$SSH_KEY" -o StrictHostKeyChecking=no ${BASTION_USER}@${BASTION_HOST} bash << 'ENDSSH'
set -eu
aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER}

cd "$1"

for f in *.yaml; do
  echo "Applying: \$f"
  kubectl apply -f \$f -n ${K8S_NAMESPACE}
done

ENDSSH
          """
        }
      }
    }

    /* ---------------------------------------------------
     * DNS FIX
     * --------------------------------------------------- */
    stage('Fix DNS Hostnames in ConfigMap') {
      when { expression { return params.FIX_DNS_HOSTNAMES } }
      steps {
        withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh',
            keyFileVariable: 'SSH_KEY', usernameVariable: 'SSH_USER')]) {

          sh """
            ssh -i "\$SSH_KEY" -o StrictHostKeyChecking=no ${BASTION_USER}@${BASTION_HOST} bash << 'ENDSSH'
set -eu
aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER}

kubectl patch configmap ${SERVICE_NAME}-config -n ${K8S_NAMESPACE} --type merge -p '{
  "data": {
    "REDIS_HOST": "redis.dev.svc.cluster.local",
    "REDIS_PORT": "6379",
    "POSTGRES_HOST": "postgres.dev.svc.cluster.local"
  }
}' || true

ENDSSH
          """
        }
      }
    }

    /* ---------------------------------------------------
     * DEPLOYMENT
     * --------------------------------------------------- */
    stage('Deploy to EKS') {
      steps {
        withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh',
            keyFileVariable: 'SSH_KEY', usernameVariable: 'SSH_USER')]) {

          sh """
            ssh -i "\$SSH_KEY" -o StrictHostKeyChecking=no ${BASTION_USER}@${BASTION_HOST} bash << 'ENDSSH'
set -eu

echo "Deploying ${SERVICE_NAME} with image ${DEPLOY_IMAGE}"

aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER}

kubectl -n ${K8S_NAMESPACE} set image deployment/${SERVICE_NAME} \
    ${SERVICE_NAME}=${DEPLOY_IMAGE} --record

kubectl -n ${K8S_NAMESPACE} rollout status deployment/${SERVICE_NAME} \
    --timeout=${ROLLOUT_TIMEOUT}

ENDSSH
          """
        }
      }
    }

  }  // STAGES END

  post {
    success {
      echo "✅ Deployment Success — ${params.SERVICE_NAME}"
    }
    failure {
      echo "❌ Deployment Failed — ${params.SERVICE_NAME}"
    }
    always {
      echo "Pipeline completed at: ${new Date()}"
    }
  }
}
