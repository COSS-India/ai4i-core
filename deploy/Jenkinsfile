pipeline {
  agent any

  parameters {
    string(name: 'BRANCH_NAME', defaultValue: 'devops', description: 'Git branch')
    choice(name: 'SERVICE_NAME', choices: """
alerting-service
api-gateway-service
asr-service
auth-service
config-service
dashboard-service
metrics-service
nmt-service
pipeline-service
telemetry-service
tts-service
""", description: 'Service to deploy')
    string(name: 'IMAGE_URI', defaultValue: '', description: 'REQUIRED: Full ECR image URI. Example: 662074586476.dkr.ecr.ap-south-1.amazonaws.com/ai4voice/nmt-service:14112025-101038-IST')
    string(name: 'ROLLOUT_TIMEOUT', defaultValue: '180s', description: 'Rollout timeout (e.g. 180s or 5m)')
    booleanParam(name: 'DEBUG_MODE', defaultValue: false, description: 'Enable verbose SSH debugging')
  }

  environment {
    AWS_REGION    = 'ap-south-1'
    EKS_CLUSTER   = 'AI4Voice-core'
    K8S_NAMESPACE = 'dev'
    BASTION_HOST  = '13.235.32.90'
    BASTION_USER  = 'ubuntu'
  }

  stages {
    stage('Validate Parameters') {
      steps {
        script {
          if (!params.IMAGE_URI || params.IMAGE_URI.trim() == '') {
            error "IMAGE_URI parameter is required! Please provide the full ECR image URI."
          }
          env.DEPLOY_IMAGE = params.IMAGE_URI.trim()
          echo "================================================"
          echo "Deployment Configuration"
          echo "================================================"
          echo "Service: ${params.SERVICE_NAME}"
          echo "Image: ${env.DEPLOY_IMAGE}"
          echo "Namespace: ${env.K8S_NAMESPACE}"
          echo "Cluster: ${env.EKS_CLUSTER}"
          echo "================================================"
        }
      }
    }

    stage('Pre-deploy Bastion Check') {
      steps {
        script {
          def sshOpts = params.DEBUG_MODE ? '-vvv' : '-v'
          sshagent(credentials: ['bastion-ssh']) {
            sh """
              set -eu
              echo '================================================'
              echo 'Testing bastion connectivity...'
              echo 'Host: ${BASTION_HOST}'
              echo 'User: ${BASTION_USER}'
              echo '================================================'
              
              ssh ${sshOpts} -o StrictHostKeyChecking=no -o ConnectTimeout=15 ${BASTION_USER}@${BASTION_HOST} 'echo "✓ Connected"; hostname; whoami'
              
              ssh -o StrictHostKeyChecking=no ${BASTION_USER}@${BASTION_HOST} 'which aws && which kubectl && echo "✓ Tools available"'
              
              echo '✅ Bastion ready'
              echo '================================================'
            """
          }
        }
      }
    }

    stage('Deploy to EKS') {
      steps {
        sshagent(credentials: ['bastion-ssh']) {
          sh """
            ssh -o StrictHostKeyChecking=no -o ServerAliveInterval=30 ${BASTION_USER}@${BASTION_HOST} bash -s <<'ENDSSH'
set -eu

echo "================================================"
echo "Starting EKS Deployment"
echo "================================================"
echo "Cluster: ${EKS_CLUSTER}"
echo "Namespace: ${K8S_NAMESPACE}"
echo "Service: ${SERVICE_NAME}"
echo "Image: ${DEPLOY_IMAGE}"
echo "================================================"

# Update kubeconfig
echo ""
echo "[1/4] Updating kubeconfig..."
aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER}

# Verify cluster
echo ""
echo "[2/4] Verifying cluster..."
kubectl cluster-info | head -1

# Update deployment
echo ""
echo "[3/4] Updating deployment..."
kubectl -n ${K8S_NAMESPACE} set image deployment/${SERVICE_NAME} ${SERVICE_NAME}=${DEPLOY_IMAGE} --record

# Wait for rollout
echo ""
echo "[4/4] Waiting for rollout..."
if kubectl -n ${K8S_NAMESPACE} rollout status deployment/${SERVICE_NAME} --timeout=${ROLLOUT_TIMEOUT}; then
  echo "✅ Rollout successful"
else
  echo "❌ Rollout failed"
  kubectl -n ${K8S_NAMESPACE} get pods -l app=${SERVICE_NAME}
  exit 1
fi

# Final status
echo ""
echo "================================================"
echo "✅ Deployment Complete"
echo "================================================"
kubectl -n ${K8S_NAMESPACE} get deployment ${SERVICE_NAME} -o wide
kubectl -n ${K8S_NAMESPACE} get pods -l app=${SERVICE_NAME}
echo "================================================"

ENDSSH
"""
        }
      }
    }
  }

  post {
    success { 
      echo ""
      echo "✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅"
      echo "✅     DEPLOYMENT SUCCESSFUL      ✅"
      echo "✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅✅"
      echo ""
      echo "Service: ${params.SERVICE_NAME}"
      echo "Image: ${env.DEPLOY_IMAGE}"
      echo "Time: ${new Date()}"
      echo ""
    }
    failure { 
      echo ""
      echo "❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌"
      echo "❌     DEPLOYMENT FAILED         ❌"
      echo "❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌❌"
      echo ""
      echo "Service: ${params.SERVICE_NAME}"
      echo ""
      echo "Debug on bastion:"
      echo "  ssh ${env.BASTION_USER}@${env.BASTION_HOST}"
      echo "  kubectl -n ${env.K8S_NAMESPACE} describe deployment ${params.SERVICE_NAME}"
      echo "  kubectl -n ${env.K8S_NAMESPACE} get pods -l app=${params.SERVICE_NAME}"
      echo ""
    }
  }
}
