pipeline {
  agent any

  parameters {
    string(name: 'BRANCH_NAME', defaultValue: 'devops', description: 'Git branch to deploy from')
    choice(name: 'SERVICE_NAME', choices: """
alerting-service
api-gateway-service
asr-service
auth-service
config-service
dashboard-service
metrics-service
nmt-service
pipeline-service
telemetry-service
tts-service
simple-ui
""", description: 'Service to deploy')
    string(name: 'IMAGE_URI', defaultValue: '', description: 'Full ECR image URI to deploy')
    string(name: 'ROLLOUT_TIMEOUT', defaultValue: '180s')
    booleanParam(name: 'APPLY_MANIFESTS', defaultValue: true)
    booleanParam(name: 'FIX_DNS_HOSTNAMES', defaultValue: true)
    booleanParam(name: 'DEBUG_MODE', defaultValue: false)
  }

  environment {
    GIT_REPO      = 'https://github.com/COSS-India/ai4i-core.git'
    AWS_REGION    = 'ap-south-1'
    EKS_CLUSTER   = 'AI4Voice-core'
    K8S_NAMESPACE = 'dev'
    BASTION_HOST  = '13.235.32.90'
    BASTION_USER  = 'ubuntu'
  }

  stages {

    /* -------------------------------
     * VALIDATE PARAMETERS
     * ------------------------------- */
    stage('Validate Parameters') {
      steps {
        script {
          if (!params.IMAGE_URI?.trim()) {
            error "IMAGE_URI cannot be empty"
          }
          env.DEPLOY_IMAGE = params.IMAGE_URI.trim()
        }

        echo """
================================================
Deployment Configuration
================================================
Service:          ${params.SERVICE_NAME}
Image:            ${env.DEPLOY_IMAGE}
Namespace:        ${env.K8S_NAMESPACE}
Cluster:          ${env.EKS_CLUSTER}
Branch:           ${params.BRANCH_NAME}
Apply Manifests:  ${params.APPLY_MANIFESTS}
Fix DNS:          ${params.FIX_DNS_HOSTNAMES}
Debug Mode:       ${params.DEBUG_MODE}
================================================
"""
      }
    }

    /* -------------------------------
     * CHECKOUT REPO
     * ------------------------------- */
    stage('Checkout Repository') {
      when { expression { params.APPLY_MANIFESTS } }
      steps {
        checkout([
          $class: 'GitSCM',
          branches: [[name: "*/${params.BRANCH_NAME}"]],
          userRemoteConfigs: [[url: "${env.GIT_REPO}"]]
        ])

        script {
          def manifestPath = "k8's_manifest/${params.SERVICE_NAME}"
          if (!fileExists(manifestPath)) {
            error "❌ Kubernetes manifests not found: ${manifestPath}"
          }
          echo "✓ Found manifests at ${manifestPath}"
        }
      }
    }

    /* -------------------------------
     * CHECK SSH TO BASTION
     * ------------------------------- */
    stage('Pre-deploy Bastion Check') {
      steps {
        withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh',
                                           keyFileVariable: 'SSH_KEY',
                                           usernameVariable: 'SSH_USER')]) {

          sh """
            ssh -o StrictHostKeyChecking=no -i "\${SSH_KEY}" ${BASTION_USER}@${BASTION_HOST} \
              "echo 'SSH OK'; which aws; which kubectl"
          """
        }
      }
    }

    /* -------------------------------
     * APPLY MANIFESTS
     * ------------------------------- */
    stage('Apply Kubernetes Manifests') {
      when { expression { params.APPLY_MANIFESTS } }
      steps {
        withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh',
                                           keyFileVariable: 'SSH_KEY',
                                           usernameVariable: 'SSH_USER')]) {

          sh """
            set -eu

            echo "Copying manifests to bastion..."

            TEMP_DIR=\$(ssh -o StrictHostKeyChecking=no -i "\${SSH_KEY}" ${BASTION_USER}@${BASTION_HOST} 'mktemp -d /tmp/k8s-manifest-XXXX')

            scp -o StrictHostKeyChecking=no -i "\${SSH_KEY}" -r "k8's_manifest/${SERVICE_NAME}/"* \
                ${BASTION_USER}@${BASTION_HOST}:\${TEMP_DIR}/

            ssh -o StrictHostKeyChecking=no -i "\${SSH_KEY}" ${BASTION_USER}@${BASTION_HOST} bash -s << 'EOF'
TEMP_DIR="\$1"
set -eu

aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER}

cd "\${TEMP_DIR}"

echo "Applying manifests..."
kubectl apply -f . -n ${K8S_NAMESPACE}

rm -rf "\${TEMP_DIR}"
EOF
            \${TEMP_DIR}
          """
        }
      }
    }

    /* -------------------------------
     * FIX DNS CONFIGMAP
     * ------------------------------- */
    stage('Fix DNS Hostnames in ConfigMap') {
      when { expression { params.FIX_DNS_HOSTNAMES } }
      steps {
        withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh',
                                           keyFileVariable: 'SSH_KEY',
                                           usernameVariable: 'SSH_USER')]) {

          sh """
            ssh -o StrictHostKeyChecking=no -i "\${SSH_KEY}" ${BASTION_USER}@${BASTION_HOST} bash -s << 'EOF'
set -eu

aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER}

CM="${SERVICE_NAME}-config"

if kubectl get configmap \${CM} -n ${K8S_NAMESPACE}; then
  kubectl patch configmap \${CM} -n ${K8S_NAMESPACE} --type merge -p '{
    "data": {
      "REDIS_HOST": "redis.dev.svc.cluster.local",
      "REDIS_PORT": "6379",
      "POSTGRES_HOST": "postgres.dev.svc.cluster.local"
    }
  }'
else
  echo "ConfigMap not found, skipping patch"
fi
EOF
          """
        }
      }
    }

    /* -------------------------------
     * DEPLOY TO EKS
     * ------------------------------- */
    stage('Deploy to EKS') {
      steps {
        withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh',
                                           keyFileVariable: 'SSH_KEY',
                                           usernameVariable: 'SSH_USER')]) {

          sh """
            ssh -o StrictHostKeyChecking=no -i "\${SSH_KEY}" ${BASTION_USER}@${BASTION_HOST} bash -s << 'EOF'
set -eu

aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER}

kubectl -n ${K8S_NAMESPACE} set image deployment/${SERVICE_NAME} ${SERVICE_NAME}=${DEPLOY_IMAGE} --record

kubectl -n ${K8S_NAMESPACE} rollout status deployment/${SERVICE_NAME} --timeout=${ROLLOUT_TIMEOUT}
EOF
          """
        }
      }
    }
  }

  /* -------------------------------
   * POST ACTIONS
   * ------------------------------- */
  post {
    success {
      echo "✅ Deployment Succeeded: ${params.SERVICE_NAME}"
    }
    failure {
      echo "❌ Deployment Failed: ${params.SERVICE_NAME}"
    }
  }
}
