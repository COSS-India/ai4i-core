pipeline {
    agent any

    parameters {
        string(name: 'BRANCH_NAME', defaultValue: 'devops', description: 'Branch to deploy from')
        choice(
            name: 'SERVICE_NAME',
            choices: """
alerting-service
api-gateway-service
asr-service
auth-service
config-service
dashboard-service
metrics-service
nmt-service
pipeline-service
telemetry-service
tts-service
simple-ui
""",
            description: 'Select the service to deploy'
        )
        string(name: 'IMAGE_URI', defaultValue: '', description: 'Full ECR image URI to deploy')
        string(name: 'ROLLOUT_TIMEOUT', defaultValue: '180s', description: 'Rollout timeout (e.g. 120s, 5m)')
    }

    environment {
        GIT_REPO      = 'https://github.com/COSS-India/ai4i-core.git'
        AWS_REGION    = 'ap-south-1'
        EKS_CLUSTER   = 'AI4Voice-core'
        K8S_NAMESPACE = 'dev'
        BASTION_HOST  = '13.235.32.90'
        BASTION_USER  = 'ubuntu'
    }

    stages {

        stage('Validate Parameters') {
            steps {
                script {
                    if (!params.IMAGE_URI?.trim()) {
                        error "IMAGE_URI is required!"
                    }

                    env.DEPLOY_IMAGE = params.IMAGE_URI.trim()

                    // Handle special deployment name for simple-ui
                    env.DEPLOYMENT_NAME =
                        (params.SERVICE_NAME == "simple-ui")
                        ? "simple-ui-frontend"
                        : params.SERVICE_NAME

                    echo "------------------------------------------------"
                    echo "Deploying service: ${params.SERVICE_NAME}"
                    echo "Deployment name:   ${env.DEPLOYMENT_NAME}"
                    echo "Image:             ${env.DEPLOY_IMAGE}"
                    echo "------------------------------------------------"
                }
            }
        }

        stage('Checkout Repository') {
            steps {
                echo "📥 Checking out repository..."
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: "*/${params.BRANCH_NAME}"]],
                    userRemoteConfigs: [[url: "${env.GIT_REPO}"]]
                ])

                script {
                    env.MANIFEST_PATH = "k8's_manifest/${params.SERVICE_NAME}"

                    if (!fileExists(env.MANIFEST_PATH)) {
                        error "❌ Kubernetes manifests not found at: ${env.MANIFEST_PATH}"
                    }

                    echo "✓ Found manifests at ${env.MANIFEST_PATH}"
                }
            }
        }

        stage('Pre-deploy Bastion Check') {
            steps {
                echo "🔐 Checking bastion connectivity..."
                withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh', keyFileVariable: 'SSH_KEY')]) {
                    sh """
                        ssh -o StrictHostKeyChecking=no -i "${SSH_KEY}" ${BASTION_USER}@${BASTION_HOST} \
                            "echo 'SSH OK'; which aws; which kubectl"
                    """
                }
            }
        }

        stage('Apply Kubernetes Manifests') {
            steps {
                echo "📦 Copying manifests to bastion..."
                withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh', keyFileVariable: 'SSH_KEY')]) {

                    sh '''
                        set -eux

                        TEMP_DIR=$(ssh -o StrictHostKeyChecking=no -i "${SSH_KEY}" '"${BASTION_USER}"'@'"${BASTION_HOST}"' \
                            mktemp -d /tmp/k8s-manifest-XXXX)

                        scp -o StrictHostKeyChecking=no -i "${SSH_KEY}" -r '"'"${MANIFEST_PATH}"'"'/* \
                            '"${BASTION_USER}"'@'"${BASTION_HOST}"':"$TEMP_DIR"/

                        echo "🚀 Applying YAML manifests..."

                        ssh -o StrictHostKeyChecking=no -i "${SSH_KEY}" '"${BASTION_USER}"'@'"${BASTION_HOST}"' bash -s <<EOF
                            set -eux
                            export AWS_REGION=${AWS_REGION}
                            export EKS_CLUSTER=${EKS_CLUSTER}

                            aws eks update-kubeconfig --region $AWS_REGION --name $EKS_CLUSTER

                            kubectl apply -f "$TEMP_DIR" -n ${K8S_NAMESPACE}

                            echo "✔ Manifests applied"
                        EOF
                    '''
                }
            }
        }

        stage('Deploy to EKS') {
            steps {
                echo "🚀 Updating deployment ${env.DEPLOYMENT_NAME} with image ${env.DEPLOY_IMAGE}..."
                withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh', keyFileVariable: 'SSH_KEY')]) {

                    sh '''
                        ssh -o StrictHostKeyChecking=no -i "${SSH_KEY}" '"${BASTION_USER}"'@'"${BASTION_HOST}"' bash -s <<EOF
                            set -eux
                            export AWS_REGION=${AWS_REGION}
                            export EKS_CLUSTER=${EKS_CLUSTER}

                            aws eks update-kubeconfig --region $AWS_REGION --name $EKS_CLUSTER

                            echo "🔄 Setting new image on deployment/${DEPLOYMENT_NAME}"

                            if ! kubectl -n ${K8S_NAMESPACE} get deployment ${DEPLOYMENT_NAME}; then
                                echo "❌ Deployment ${DEPLOYMENT_NAME} not found!"
                                exit 1
                            fi

                            kubectl -n ${K8S_NAMESPACE} set image deployment/${DEPLOYMENT_NAME} \
                                ${DEPLOYMENT_NAME}=${DEPLOY_IMAGE} --record

                            kubectl -n ${K8S_NAMESPACE} rollout status deployment/${DEPLOYMENT_NAME} \
                                --timeout=${ROLLOUT_TIMEOUT}
                        EOF
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "✅ Deployment Success: ${params.SERVICE_NAME}"
        }
        failure {
            echo "❌ Deployment Failed: ${params.SERVICE_NAME}"
            echo "   Image:     ${env.DEPLOY_IMAGE}"
            echo "   Namespace: ${env.K8S_NAMESPACE}"
            echo "   Cluster:   ${env.EKS_CLUSTER}"
            echo "👉 Check console log for errors"
        }
    }
}
