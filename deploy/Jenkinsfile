pipeline {
    agent any

    parameters {
        string(name: 'BRANCH_NAME', defaultValue: 'devops')
        choice(name: 'SERVICE_NAME', choices: """
alerting-service
api-gateway-service
asr-service
auth-service
config-service
dashboard-service
metrics-service
nmt-service
pipeline-service
telemetry-service
tts-service
simple-ui
""")
        string(name: 'IMAGE_URI', defaultValue: '', description: 'Full ECR image URI')
        booleanParam(name: 'APPLY_MANIFESTS', defaultValue: true)
    }

    environment {
        GIT_REPO      = 'https://github.com/COSS-India/ai4i-core.git'
        AWS_REGION    = 'ap-south-1'
        EKS_CLUSTER   = 'AI4Voice-core'
        K8S_NAMESPACE = 'dev'
        BASTION_HOST  = '13.235.32.90'
        BASTION_USER  = 'ubuntu'
    }

    stages {

        /* -------------------------------
         * Validate User Inputs
         * ------------------------------- */
        stage('Validate Parameters') {
            steps {
                script {
                    if (!params.IMAGE_URI?.trim()) {
                        error "IMAGE_URI cannot be empty!"
                    }

                    env.DEPLOY_IMAGE = params.IMAGE_URI.trim()
                    MANIFEST_PATH = "k8's_manifest/${params.SERVICE_NAME}"

                    echo """
=========================================================
SERVICE      : ${params.SERVICE_NAME}
IMAGE        : ${env.DEPLOY_IMAGE}
BRANCH       : ${params.BRANCH_NAME}
NAMESPACE    : ${env.K8S_NAMESPACE}
CLUSTER      : ${env.EKS_CLUSTER}
ManifestPath : ${MANIFEST_PATH}
=========================================================
"""
                }
            }
        }

        /* -------------------------------
         * Checkout Git Repository
         * ------------------------------- */
        stage('Checkout Repository') {
            steps {
                echo "📥 Checking out repository..."
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: "*/${params.BRANCH_NAME}"]],
                    userRemoteConfigs: [[url: "${env.GIT_REPO}"]]
                ])

                script {
                    if (!fileExists(MANIFEST_PATH)) {
                        error "❌ Kubernetes manifests not found at: ${MANIFEST_PATH}"
                    }

                    echo "✓ Found manifests at ${MANIFEST_PATH}"
                }
            }
        }

        /* -------------------------------
         * Check SSH Access to Bastion
         * ------------------------------- */
        stage('Pre-deploy Bastion Check') {
            steps {
                withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh', keyFileVariable: 'SSH_KEY')]) {

                    sh '''
                        echo "🔐 Checking bastion connectivity..."

                        ssh -o StrictHostKeyChecking=no \
                            -i "$SSH_KEY" \
                            '"'"'"$BASTION_USER"'"'"'"@'"'"'"$BASTION_HOST"'"'"'" \
                            'echo "SSH OK"; which aws; which kubectl'
                    '''
                }
            }
        }

        /* -------------------------------
         * Apply Kubernetes Manifest Files
         * ------------------------------- */
        stage('Apply Kubernetes Manifests') {
            when {
                expression { return params.APPLY_MANIFESTS }
            }
            steps {
                echo "📦 Copying manifests to bastion..."

                withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh', keyFileVariable: 'SSH_KEY')]) {

                    sh """
                        set -eux

                        # Create temp dir safely
                        TEMP_DIR=\$(ssh -o StrictHostKeyChecking=no -i "\$SSH_KEY" \
                            '\"'\"'\"'\"'\$BASTION_USER'\"'\"'\"'\"'@'\"'\"'\"'\"'\$BASTION_HOST'\"'\"'\"'\"' \
                            mktemp -d /tmp/k8s-manifest-XXXX)

                        echo "Temp dir: \$TEMP_DIR"

                        # Copy manifests
                        scp -o StrictHostKeyChecking=no -i "\$SSH_KEY" -r "${MANIFEST_PATH}/"* \
                            "\$BASTION_USER@\$BASTION_HOST:\$TEMP_DIR/"

                        echo "🚀 Applying YAML manifests..."

                        ssh -o StrictHostKeyChecking=no -i "\$SSH_KEY" \
                            "\$BASTION_USER@\$BASTION_HOST" bash <<'EOF'
                            set -eux
                            aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER}
                            kubectl apply -f "$TEMP_DIR" -n ${K8S_NAMESPACE}
                            echo "✔ Manifests applied successfully"
EOF
                    """
                }
            }
        }

        /* -------------------------------
         * Update Deployment Image
         * ------------------------------- */
        stage('Deploy to EKS') {
            steps {
                withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh', keyFileVariable: 'SSH_KEY')]) {

                    echo "🚀 Updating deployment ${params.SERVICE_NAME} with image ${env.DEPLOY_IMAGE}"

                    sh """
                        ssh -o StrictHostKeyChecking=no -i "\$SSH_KEY" \
                            "\$BASTION_USER@\$BASTION_HOST" bash <<'EOF'
                            set -eux

                            # Update kubeconfig
                            aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER}

                            # Patch image
                            kubectl -n ${K8S_NAMESPACE} set image deployment/${params.SERVICE_NAME} \
                                ${params.SERVICE_NAME}=${env.DEPLOY_IMAGE} --record

                            # Rollout
                            kubectl -n ${K8S_NAMESPACE} rollout status deployment/${params.SERVICE_NAME} --timeout=180s
EOF
                    """
                }
            }
        }

    } // stages

    /* -------------------------------
     * POST ACTIONS
     * ------------------------------- */
    post {
        success {
            echo """
✅ Deployment Success
Service:   ${params.SERVICE_NAME}
Image:     ${env.DEPLOY_IMAGE}
Namespace: ${env.K8S_NAMESPACE}
Cluster:   ${env.EKS_CLUSTER}
"""
        }
        failure {
            echo """
❌ Deployment Failed
Service:   ${params.SERVICE_NAME}
Image:     ${env.DEPLOY_IMAGE}
Namespace: ${env.K8S_NAMESPACE}
Cluster:   ${env.EKS_CLUSTER}

👉 Check console log for errors
"""
        }
    }

}
