pipeline {
  agent any

  parameters {
    string(name: 'BRANCH_NAME', defaultValue: 'devops', description: 'Git branch to deploy from')
    choice(name: 'SERVICE_NAME', choices: """
alerting-service
api-gateway-service
asr-service
auth-service
config-service
dashboard-service
metrics-service
nmt-service
pipeline-service
telemetry-service
tts-service
simple-ui
""", description: 'Service to deploy')
    string(name: 'IMAGE_URI', defaultValue: '', description: 'Full ECR image URI')
    booleanParam(name: 'APPLY_MANIFESTS', defaultValue: true)
  }

  environment {
    GIT_REPO      = 'https://github.com/COSS-India/ai4i-core.git'
    AWS_REGION    = 'ap-south-1'
    EKS_CLUSTER   = 'AI4Voice-core'
    K8S_NAMESPACE = 'dev'
    BASTION_HOST  = '13.235.32.90'
    BASTION_USER  = 'ubuntu'
  }

  stages {

    /* ------------------------------ VALIDATION ------------------------------ */

    stage('Validate Inputs') {
      steps {
        script {
          if (!params.IMAGE_URI?.trim()) {
            error "IMAGE_URI is required!"
          }
          echo "Deploying service: ${params.SERVICE_NAME}"
          echo "Image: ${params.IMAGE_URI}"
        }
      }
    }

    /* ------------------------------ CHECKOUT ------------------------------ */

    stage('Checkout Repository') {
      when { expression { params.APPLY_MANIFESTS } }
      steps {
        echo "📥 Checking out repository..."
        checkout([
          $class: 'GitSCM',
          branches: [[name: "*/${params.BRANCH_NAME}"]],
          userRemoteConfigs: [[url: "${env.GIT_REPO}"]]
        ])

        script {
          MANIFEST_PATH = "k8's_manifest/${params.SERVICE_NAME}"
          if (!fileExists(MANIFEST_PATH)) {
            error "❌ Kubernetes manifests not found at: ${MANIFEST_PATH}"
          }
          echo "✓ Found manifests at ${MANIFEST_PATH}"
        }
      }
    }

    /* --------------------------- SSH CHECK --------------------------- */

    stage('Pre-deploy Bastion Check') {
      steps {
        withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh', keyFileVariable: 'SSH_KEY')]) {

          sh '''#!/bin/bash
            set -e
            echo "🔐 Checking bastion connectivity..."

            ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" '${BASTION_USER}'@'${BASTION_HOST}' \
              "echo 'SSH OK'; which aws; which kubectl"
          '''
        }
      }
    }

    /* ---------------------- APPLY MANIFESTS ----------------------- */

    stage('Apply Kubernetes Manifests') {
      when { expression { params.APPLY_MANIFESTS } }
      steps {
        withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh', keyFileVariable: 'SSH_KEY')]) {

          sh '''#!/bin/bash
            set -e

            echo "📦 Copying manifests to bastion..."

            MANIFEST_DIR="k8's_manifest/${SERVICE_NAME}"

            # Create remote temp directory
            TEMP_DIR=$(ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" '${BASTION_USER}'@'${BASTION_HOST}' \
              "mktemp -d /tmp/k8s-manifest-XXXX")
            echo "✓ Created remote directory: $TEMP_DIR"

            # Copy YAML files only
            scp -o StrictHostKeyChecking=no -i "$SSH_KEY" \
              ${MANIFEST_DIR}/*.yaml \
              '${BASTION_USER}'@'${BASTION_HOST}':"$TEMP_DIR"/

            echo "🚀 Applying YAML manifests..."

            ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" '${BASTION_USER}'@'${BASTION_HOST}' << 'ENDSSH'
              set -e

              echo "Updating kubeconfig..."
              aws eks update-kubeconfig --region '${AWS_REGION}' --name '${EKS_CLUSTER}'

              echo "Applying manifests from: ${TEMP_DIR}"
              kubectl apply -f ${TEMP_DIR} -n '${K8S_NAMESPACE}'

              echo "✨ Manifests applied successfully"
ENDSSH

          '''
        }
      }
    }

    /* ------------------------- DEPLOY TO EKS ------------------------ */

    stage('Deploy to EKS') {
      steps {
        withCredentials([sshUserPrivateKey(credentialsId: 'bastion-ssh', keyFileVariable: 'SSH_KEY')]) {

          sh '''#!/bin/bash
            set -e

            echo "🚀 Updating image in EKS deployment..."

            ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" '${BASTION_USER}'@'${BASTION_HOST}' << 'ENDSSH'
              set -e

              aws eks update-kubeconfig --region '${AWS_REGION}' --name '${EKS_CLUSTER}'

              echo "🔄 Setting new image..."
              kubectl -n '${K8S_NAMESPACE}' set image deployment/'${SERVICE_NAME}' \
                  '${SERVICE_NAME}'='${IMAGE_URI}' --record

              echo "⏳ Waiting for rollout..."
              kubectl -n '${K8S_NAMESPACE}' rollout status deployment/'${SERVICE_NAME}' --timeout=180s

              echo "🎉 Rollout complete!"
ENDSSH

          '''
        }
      }
    }

  }

  post {
    success {
      echo "✅ Deployment Successful: ${params.SERVICE_NAME}"
    }
    failure {
      echo "❌ Deployment Failed: ${params.SERVICE_NAME}"
    }
  }
}
